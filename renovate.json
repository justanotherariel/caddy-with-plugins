{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update xcaddy module dependencies",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "--with\\s+(?<depName>[a-zA-Z0-9./_-]+?)@(?<currentValue>[^\\s\\\\]+)"
      ],
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
